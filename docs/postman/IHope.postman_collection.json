{
  "info": {
    "name": "IHope API",
    "description": "IHope 本地开发 API 集合。选 IHope Local 环境；登录/刷新后 token 自动写入；忘记密码（dev）自动写入 reset_token。",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "device_id", "value": "postman-device-1" },
    { "key": "access_token", "value": "" },
    { "key": "refresh_token", "value": "" },
    { "key": "old_refresh_token", "value": "" },
    { "key": "reset_token", "value": "" },
    { "key": "login_password", "value": "password123" }
  ],
  "item": [
    {
      "name": "0. 健康检查",
      "item": [
        {
          "name": "GET /api/health",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('health check ok', function () {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(pm.response.json().ok).to.eql(true);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/health"
          }
        }
      ]
    },
    {
      "name": "1. 注册与登录",
      "item": [
        {
          "name": "POST /api/auth/register",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('register ok or already exists', function () {",
                  "  pm.expect([201, 409]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice@example.com\",\n  \"username\": \"alice\",\n  \"password\": \"password123\",\n  \"identity_public_key\": \"dGVzdF9pZGVudGl0eV9rZXk=\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/api/auth/register"
          }
        },
        {
          "name": "POST /api/auth/login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('login returns tokens and saves variables', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.access_token).to.be.a('string').and.not.empty;",
                  "  pm.expect(json.refresh_token).to.be.a('string').and.not.empty;",
                  "  pm.collectionVariables.set('access_token', json.access_token);",
                  "  pm.collectionVariables.set('refresh_token', json.refresh_token);",
                  "  if (pm.environment.name) {",
                  "    pm.environment.set('access_token', json.access_token);",
                  "    pm.environment.set('refresh_token', json.refresh_token);",
                  "  }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice@example.com\",\n  \"password\": \"{{login_password}}\",\n  \"device_id\": \"{{device_id}}\",\n  \"device_name\": \"Postman\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "GET /api/users/me",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('current user returned', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.email).to.be.a('string');",
                  "  pm.expect(json.username).to.be.a('string');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{baseUrl}}/api/users/me"
          }
        },
        {
          "name": "POST /api/auth/refresh",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('refresh returns new tokens and saves variables', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.access_token).to.be.a('string').and.not.empty;",
                  "  pm.expect(json.refresh_token).to.be.a('string').and.not.empty;",
                  "  pm.collectionVariables.set('access_token', json.access_token);",
                  "  pm.collectionVariables.set('refresh_token', json.refresh_token);",
                  "  if (pm.environment.name) {",
                  "    pm.environment.set('access_token', json.access_token);",
                  "    pm.environment.set('refresh_token', json.refresh_token);",
                  "  }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\",\n  \"device_id\": \"{{device_id}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/api/auth/refresh"
          }
        }
      ]
    },
    {
      "name": "2. 找回密码",
      "item": [
        {
          "name": "POST /api/auth/forgot-password",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('forgot password accepted', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.message).to.be.a('string');",
                  "  const rt = pm.collectionVariables.get('refresh_token') || pm.environment.get('refresh_token');",
                  "  if (rt) {",
                  "    pm.collectionVariables.set('old_refresh_token', rt);",
                  "    if (pm.environment.name) pm.environment.set('old_refresh_token', rt);",
                  "  }",
                  "  if (json.dev_reset_token) {",
                  "    const token = String(json.dev_reset_token).trim();",
                  "    pm.collectionVariables.set('reset_token', token);",
                  "    if (pm.environment.name) pm.environment.set('reset_token', token);",
                  "  }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice@example.com\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/api/auth/forgot-password",
            "description": "开发环境 MAIL_DRIVER=log 时，响应含 dev_reset_token 并自动写入 reset_token；同时保存 old_refresh_token 供 reset 后验证。"
          }
        },
        {
          "name": "POST /api/auth/reset-password",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('password reset ok', function () {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(pm.response.json().message).to.eql('password updated');",
                  "});",
                  "pm.collectionVariables.set('login_password', 'newpassword123');",
                  "if (pm.environment.name) pm.environment.set('login_password', 'newpassword123');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{reset_token}}\",\n  \"password\": \"newpassword123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/api/auth/reset-password"
          }
        },
        {
          "name": "POST /api/auth/login (after reset)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('login with new password ok', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('access_token', json.access_token);",
                  "  pm.collectionVariables.set('refresh_token', json.refresh_token);",
                  "  if (pm.environment.name) {",
                  "    pm.environment.set('access_token', json.access_token);",
                  "    pm.environment.set('refresh_token', json.refresh_token);",
                  "  }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice@example.com\",\n  \"password\": \"newpassword123\",\n  \"device_id\": \"{{device_id}}\",\n  \"device_name\": \"Postman\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "POST /api/auth/refresh (should fail after reset)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('old refresh token invalidated after password reset', function () {",
                  "  pm.response.to.have.status(401);",
                  "  pm.expect(pm.response.json().error).to.eql('invalid_refresh');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{old_refresh_token}}\",\n  \"device_id\": \"{{device_id}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/api/auth/refresh",
            "description": "使用 forgot-password 时保存的 old_refresh_token；期望 401 invalid_refresh。"
          }
        }
      ]
    }
  ]
}
