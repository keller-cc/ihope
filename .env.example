# =============================================================================
# IHope 环境变量模板 → 复制到 deploy/.env
#   cd deploy && copy ..\.env.example .env
# =============================================================================

# --- 数据库 ---

DB_PASSWORD=devpassword
POSTGRES_USER=ihope
POSTGRES_DB=ihope
DB_HOST=127.0.0.1
DB_PORT=5432

# --- JWT ---

JWT_SECRET=change_me_jwt_secret_at_least_32_chars
# access_token 有效期（分钟）
JWT_ACCESS_TTL_MIN=15

# --- 应用 ---

APP_PUBLIC_URL=http://localhost:8080
SERVER_PORT=8080
# 跨域；开发可用 *，生产填前端域名
CORS_ALLOW_ORIGIN=*

# --- 限流（注册/登录） ---

# 同一 IP + 路径，在窗口内最多几次
LOGIN_RATE_LIMIT=5
# 窗口长度（秒）
LOGIN_RATE_WINDOW_SEC=60

# --- 找回密码 ---

# 重置 token 有效期（分钟）
RESET_TOKEN_TTL_MIN=30

# --- 邮件 ---

MAIL_DRIVER=log
MAIL_FROM=noreply@example.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# --- 推送（可选；不配则仅日志 [push]，不真发系统通知） ---

# 国内 Android（极光）：platform=android_cn 的设备
# JPUSH_APP_KEY=
# JPUSH_MASTER_SECRET=

# 海外 Android/iOS（FCM）：platform=android / ios 的设备
# FCM_SERVER_KEY=

# --- 管理后台（Web /admin/） ---

# 逗号分隔的管理员邮箱；这些账号登录后自动获得 is_admin
# ADMIN_EMAILS=ops@example.com
# 可选：管理页静态文件目录（默认自动查找仓库 admin/）
# ADMIN_WEB_DIR=
