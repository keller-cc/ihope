# 复制为 deploy/.env 或项目根 .env（勿提交真实 .env）

# 数据库
DB_PASSWORD=change_me_strong_password
POSTGRES_USER=ihope
POSTGRES_DB=ihope

# JWT（至少 32 字符随机串）
JWT_SECRET=change_me_jwt_secret_at_least_32_chars

# 应用
APP_PUBLIC_URL=http://localhost:8080
SERVER_PORT=8080

# 邮件：开发用 log 只打印到控制台；生产用 smtp
MAIL_DRIVER=log
MAIL_FROM=noreply@example.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
