# =============================================================================
# IHope 环境变量模板 → 复制到 deploy/.env
#   cd deploy && copy ..\.env.example .env
# =============================================================================

# --- 数据库 ---

DB_PASSWORD=devpassword
POSTGRES_USER=ihope
POSTGRES_DB=ihope
DB_HOST=127.0.0.1
DB_PORT=5432

# --- JWT ---

JWT_SECRET=change_me_jwt_secret_at_least_32_chars
# access_token 有效期（分钟）
JWT_ACCESS_TTL_MIN=15
# refresh_token 闲置超过此天数后不可用（0=永不过期，仅建议开发环境）
REFRESH_TOKEN_TTL_DAYS=30

# --- 应用 ---

# 对外 URL（邮件链接、App 更新包地址、health client 配置）
APP_PUBLIC_URL=http://localhost:8080
# Cloudflare Tunnel 内测：APP_PUBLIC_URL=http://im.cplprince.top
# 生产 VPS + HTTPS：APP_PUBLIC_URL=https://im.cplprince.top
SERVER_PORT=8080
# 生产 compose 对外 HTTP 端口（nginx）
# HTTP_PORT=80
# 跨域；开发可用 *，Tunnel/VPS 填公网域名
CORS_ALLOW_ORIGIN=*
# Tunnel 内测：CORS_ALLOW_ORIGIN=http://im.cplprince.top

# --- 限流（注册/登录） ---

# 同一 IP + 路径，在窗口内最多几次
LOGIN_RATE_LIMIT=5
# 窗口长度（秒）
LOGIN_RATE_WINDOW_SEC=60

# --- 找回密码 ---

# 重置 token 有效期（分钟）
RESET_TOKEN_TTL_MIN=30

# --- 邮件 ---

MAIL_DRIVER=log
MAIL_FROM=noreply@example.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# --- 推送（可选；不配则仅日志 [push]，不真发系统通知） ---

# 国内 Android（极光）：platform=android_cn 的设备
# JPUSH_APP_KEY=
# JPUSH_MASTER_SECRET=

# 海外 Android/iOS（FCM）：platform=android / ios 的设备
# FCM_SERVER_KEY=

# --- 文件上传 ---

# 加密附件单文件上限（字节）；0 = 不限制；默认 300MB
MAX_ENCRYPTED_FILE_BYTES=314572800
# 1t1 网盘外链（App 从 /api/health 拉取）
CLOUD_DRIVE_URL=https://1t1.org
# 实例版本（格式：yyyy-MM-dd x.y.z version；App 检查更新用）
SERVER_VERSION=2026-07-03 0.1.0 version
# 最新 App 包 URL；留空则默认 {APP_PUBLIC_URL}/api/app/download
# APP_DOWNLOAD_URL=https://example.com/ihope.apk
# 自建分发：将 APK 复制到 backend/uploads/releases/latest.apk
# 排空等待秒数（SIGTERM 或 POST /api/admin/drain）
DRAIN_SECONDS=15

# --- 开发无感升级（devproxy + upgrade-dev.ps1）---
# App 固定连 PUBLIC_PORT；后端在 BACKEND_PORT_A/B 间交替
PUBLIC_PORT=8080
BACKEND_PORT_A=8081
BACKEND_PORT_B=8082
# DEFAULT_BACKEND_PORT=8081  # devproxy 默认转发端口


# 与 App 用户账号无关；管理页输入此密钥即可
ADMIN_SECRET=change_me_admin_secret_at_least_32_chars
# 可选：管理页静态文件目录（默认自动查找仓库 admin/）
# ADMIN_WEB_DIR=
