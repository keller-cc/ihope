# IHope 生产 HTTPS 反代示例 — 复制为 nginx-ssl.conf 并改域名 / 证书路径
# docker-compose 中替换 nginx.conf 挂载，并增加 443 端口与证书卷（见 deploy/README.md）
# 勿提交真实证书；certbot 默认路径 /etc/letsencrypt/live/<domain>/

upstream ihope_backend {
    server backend:8080;
    keepalive 32;
}

# HTTP → HTTPS
server {
    listen 80;
    server_name im.example.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name im.example.com;

    ssl_certificate     /etc/letsencrypt/live/im.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/im.example.com/privkey.pem;
    ssl_session_timeout 1d;
    ssl_session_cache shared:SSL:10m;
    ssl_protocols TLSv1.2 TLSv1.3;

    client_max_body_size 320m;

    location /ws {
        proxy_pass http://ihope_backend;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
    }

    location / {
        proxy_pass http://ihope_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
        proxy_request_buffering off;
    }
}
